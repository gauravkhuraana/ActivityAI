{
  "name": "group-activity-tests",
  "version": "1.0.0",
  "type": "module",
  "description": "Orchestrated testing suite: Playwright E2E + Backend API + BDD",
  "scripts": {
    "test": "npm run test:backend && npm run test:bdd && npm run test:e2e",
    "test:backend": "npx jest --config tests/backend/jest.config.js",
    "test:bdd": "npx cucumber-js --config tests/bdd/cucumber.js",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "report": "npx playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@cucumber/cucumber": "^11.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  }
}
